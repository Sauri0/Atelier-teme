{% comment %}
  Atelier - Thank You Page Template
{% endcomment %}

<style>
  .thank-you-page {
    padding: var(--spacing-xl) 0;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .thank-you-card {
    background: var(--color-surface);
    padding: var(--spacing-xl);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-subtle);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .success-icon {
    width: 64px;
    height: 64px;
    fill: var(--color-accent); /* Navy Green #1B263B */
    margin-bottom: var(--spacing-sm);
  }

  .thank-you-title {
    font-size: 2rem;
    color: var(--color-accent);
    font-family: var(--font-heading);
    margin-bottom: var(--spacing-sm);
  }

  .order-number {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-main);
    font-weight: 500;
  }

  .order-number span {
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .thank-you-message {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: var(--spacing-lg);
  }

  .continue-shopping-btn {
    padding: 16px 32px;
    background: var(--color-primary); /* Aqua Green #20B2AA */
    color: white;
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: var(--transition-base);
    display: inline-block;
  }

  .continue-shopping-btn:hover {
    background: #178a84;
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }
</style>

<div class="container thank-you-page">
  <div class="thank-you-card">
    
    <!-- Success Checkmark -->
    <svg class="success-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
    </svg>

    <h1 class="thank-you-title">Thank You, {{ customer.first_name | default: 'Guest' }}!</h1>
    
    <div class="order-number">
      Order Confirmed: <span>#{{ checkout.order_number | default: 'ATELIER-1004' }}</span>
    </div>

    <p class="thank-you-message">
      Welcome to Atelier. We have received your order and are currently processing it. A confirmation email with your detailed receipt and tracking information will be sent to you shortly.
    </p>

    <a href="{{ routes.root_url }}" class="continue-shopping-btn">
      Continue Shopping
    </a>
  </div>
</div>
