{% comment %}
  Track Order Template - Visual Stepper
{% endcomment %}

<style>
  .track-order-page {
    padding: var(--spacing-xl) 0;
    max-width: 800px;
    margin: 0 auto;
  }

  .track-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .track-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    background: var(--color-surface);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-subtle);
  }

  @media (min-width: 768px) {
    .track-form {
      flex-direction: row;
    }
  }

  .track-input {
    flex-grow: 1;
    padding: 16px;
    border: 1px solid rgba(27, 38, 59, 0.1);
    border-radius: var(--border-radius);
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .track-input:focus {
    outline: none;
    border-color: var(--color-primary); /* Aqua Green */
  }

  .track-btn {
    padding: 16px 32px;
  }

  /* Visual Stepper (Demo UI) */
  .stepper-container {
    margin-top: var(--spacing-xl);
    padding: var(--spacing-lg);
    background: var(--color-surface);
    border-radius: var(--border-radius);
    display: none; /* Hidden until search */
  }

  .stepper {
    display: flex;
    justify-content: space-between;
    position: relative;
    padding-top: 20px;
  }

  /* Line connecting steps */
  .stepper::before {
    content: '';
    position: absolute;
    top: 30px;
    left: 0;
    right: 0;
    height: 4px;
    background: #E1E3E4;
    z-index: 1;
  }

  .step {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 0.85rem;
  }

  .step-circle {
    width: 24px;
    height: 24px;
    background: #E1E3E4;
    border-radius: 50%;
    margin: 0 auto 8px auto;
    transition: var(--transition-base);
  }

  .step.active .step-circle {
    background: var(--color-primary); /* Aqua Green */
    box-shadow: 0 0 0 6px rgba(32, 178, 170, 0.2);
  }

  .step.active, .step.completed {
    color: var(--color-accent); /* Navy Green */
    font-weight: 600;
  }

  .step.completed .step-circle {
    background: var(--color-accent);
  }
</style>

<div class="container track-order-page">
  <div class="track-header">
    <h1>Track Your Order</h1>
    <p>Enter your tracking number below to see real-time updates.</p>
  </div>

  <div class="track-form">
    <input type="text" id="trackingNumber" class="track-input" placeholder="e.g. SW18392095" required>
    <button type="button" class="btn btn-primary track-btn" onclick="simulateTracking()">Track Now</button>
  </div>

  <!-- Stepper Simulation -->
  <div class="stepper-container" id="MockStepper">
    <h3 style="margin-bottom: 24px; text-align: center;">Order Status: In Transit</h3>
    <div class="stepper">
      <div class="step completed">
        <div class="step-circle"></div>
        Order Placed
      </div>
      <div class="step completed">
        <div class="step-circle"></div>
        Processed
      </div>
      <div class="step active">
        <div class="step-circle"></div>
        In Transit
      </div>
      <div class="step">
        <div class="step-circle"></div>
        Delivered
      </div>
    </div>
  </div>
</div>

<script>
  function simulateTracking() {
    const input = document.getElementById('trackingNumber').value;
    const stepper = document.getElementById('MockStepper');
    if(input.length > 5) {
      stepper.style.display = 'block';
    } else {
      alert("Please enter a valid tracking number.");
    }
  }
</script>
