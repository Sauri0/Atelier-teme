{% comment %}
  Collection List - The Digital Atelier Grid
{% endcomment %}

<style>
  .collection-list-section {
    padding: var(--spacing-xl) 0;
  }
  
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  @media (min-width: 1024px) {
    .collection-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: var(--spacing-lg);
    }
  }

  .collection-card {
    position: relative;
    border-radius: var(--border-radius);
    overflow: hidden;
    aspect-ratio: 4/5;
    text-decoration: none;
    background-color: var(--color-surface);
    box-shadow: var(--shadow-subtle);
    transition: var(--transition-base);
  }

  .collection-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .collection-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .collection-card:hover .collection-image {
    transform: scale(1.05);
  }

  .collection-label {
    position: absolute;
    bottom: var(--spacing-md);
    left: var(--spacing-md);
    right: var(--spacing-md);
    padding: 12px;
    border-radius: 8px;
    text-align: center;
    color: var(--color-text-main);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.1rem;
    /* Glassmorphism utility */
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
</style>

<div class="collection-list-section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="collection-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection.url | default: '#' }}" class="collection-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img 
              src="{{ block.settings.image | image_url: width: 800 }}" 
              alt="{{ block.settings.title | escape }}" 
              class="collection-image"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- elsif block.settings.collection.image != blank -%}
             <img 
              src="{{ block.settings.collection.image | image_url: width: 800 }}" 
              alt="{{ block.settings.title | escape }}" 
              class="collection-image"
              loading="lazy"
              width="{{ block.settings.collection.image.width }}"
              height="{{ block.settings.collection.image.height }}"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'collection-image placeholder-svg' }}
          {%- endif -%}
          
          <div class="collection-label">
            {{ block.settings.title | default: block.settings.collection.title | default: 'Collection' }}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Shop by Category",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Desktop Columns"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 6,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Title (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List Grid",
      "blocks": [
        {"type": "collection"},
        {"type": "collection"},
        {"type": "collection"}
      ]
    }
  ]
}
{% endschema %}
