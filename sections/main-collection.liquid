{% comment %}
  Main Collection Section - Atelier Luxury
{% endcomment %}

<style>
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
    padding: var(--spacing-lg) 0;
  }
  @media (min-width: 768px) {
    .collection-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .collection-grid { grid-template-columns: repeat(4, 1fr); gap: var(--spacing-lg); }
  }

  /* Product Card Hover Reveal */
  .product-card {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .card-media {
    position: relative;
    aspect-ratio: 4/5;
    background: var(--color-surface);
    overflow: hidden;
    border-radius: var(--border-radius);
    margin-bottom: var(--spacing-sm);
  }

  .primary-img, .secondary-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .secondary-img {
    opacity: 0;
  }

  .product-card:hover .secondary-img {
    opacity: 1;
  }
  
  .product-card:hover .primary-img {
    opacity: 0;
  }

  .product-card:hover .card-media img {
    transform: scale(1.05);
  }

  .card-info {
    padding: 8px 0;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    margin: 0 0 4px;
  }

  .card-price {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  /* Filter Bar */
  .filter-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid rgba(27, 38, 59, 0.05);
    margin-bottom: var(--spacing-md);
  }

  .filter-count { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-light); }
  
  .filter-sort {
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.9rem;
    cursor: pointer;
  }
</style>

<div class="container animate-fade-up">
  <div class="filter-bar">
    <div class="filter-count">{{ collection.products_count }} Products</div>
    <select class="filter-sort">
      <option>Featured</option>
      <option>Newest</option>
      <option>Price: Low to High</option>
    </select>
  </div>

  <div class="collection-grid">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="product-card">
        <div class="card-media">
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="primary-img" loading="lazy">
          {% if product.images[1] != blank %}
            <img src="{{ product.images[1] | image_url: width: 800 }}" alt="{{ product.title }}" class="secondary-img" loading="lazy">
          {% endif %}
        </div>
        <div class="card-info">
          <h3 class="card-title">{{ product.title }}</h3>
          <div class="card-price">{{ product.price | money }}</div>
        </div>
      </a>
    {% else %}
      {% comment %} 
        Digital Atelier Empty State - Luxury Placeholders 
        Shopify supports product-1 through product-6.
      {% endcomment %}
      {% for i in (1..6) %}
        <a href="/" class="product-card animate-fade-up" style="animation-delay: {{ i | times: 0.1 }}s">
          <div class="card-media">
            {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg primary-img' }}
          </div>
          <div class="card-info">
            <h3 class="card-title">Atelier Piece 0{{ i }}</h3>
            <div class="card-price">$450.00</div>
          </div>
        </a>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Main Collection",
  "settings": [],
  "presets": [ { "name": "Main Collection" } ]
}
{% endschema %}
