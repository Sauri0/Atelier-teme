{% comment %}
  Trust Banner Section - Minimalist Icons & Marquee on Mobile
{% endcomment %}

<style>
  .trust-banner-wrapper {
    background-color: var(--color-surface);
    padding: var(--spacing-sm) 0;
    overflow: hidden;
  }
  
  .trust-banner-inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--color-accent); /* Navy Green #1B263B */
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  
  .trust-icon svg {
    width: 24px;
    height: 24px;
    fill: var(--color-primary); /* Aqua Green #20B2AA */
  }

  /* Desktop Flex Grid */
  @media (min-width: 768px) {
    .trust-banner-inner {
      justify-content: center;
      flex-wrap: wrap;
    }
  }

  /* Mobile Marquee Animation */
  @media (max-width: 767px) {
    .trust-banner-container {
      width: 100vw;
      overflow: hidden;
    }
    .trust-banner-inner {
      width: max-content;
      animation: marquee 15s linear infinite;
    }
    
    @keyframes marquee {
      0% { transform: translate3d(0, 0, 0); }
      100% { transform: translate3d(-50%, 0, 0); }
    }
  }
</style>

<div class="trust-banner-wrapper">
  <div class="container trust-banner-container">
    <div class="trust-banner-inner">
      {%- for block in section.blocks -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != 'none' -%}
            <span class="trust-icon">
              {% render 'icon-trust', icon: block.settings.icon %}
            </span>
          {%- endif -%}
          <span>{{ block.settings.title | escape }}</span>
        </div>
      {%- endfor -%}
      <!-- Duplicate for seamless standard marquee on mobile -->
      <div class="trust-item hide-on-desktop" aria-hidden="true">
        {%- for block in section.blocks -%}
           <span class="trust-icon" style="margin-left: var(--spacing-lg);">
              {% render 'icon-trust', icon: block.settings.icon %}
           </span>
           <span style="margin-left: var(--spacing-sm);">{{ block.settings.title | escape }}</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "tag": "section",
  "class": "trust-banner-section",
  "settings": [],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Fast Shipping to USA/EU",
          "label": "Benefit Title"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "shipping", "label": "Shipping Truck"},
            {"value": "guarantee", "label": "Shield Guarantee"},
            {"value": "support", "label": "24/7 Support"},
            {"value": "none", "label": "None"}
          ],
          "default": "shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner",
      "blocks": [
        {"type": "benefit", "settings": {"title": "Fast Shipping to USA/EU", "icon": "shipping"}},
        {"type": "benefit", "settings": {"title": "30-Day Money Back Guarantee", "icon": "guarantee"}},
        {"type": "benefit", "settings": {"title": "24/7 Premium Support", "icon": "support"}}
      ]
    }
  ]
}
{% endschema %}
