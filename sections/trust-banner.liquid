{% comment %}
  Trust Banner Section
{% endcomment %}

<style>
  .trust-banner-wrapper {
    background-color: var(--color-surface);
    padding: var(--spacing-md) 0;
    border-top: 1px solid rgba(27, 38, 59, 0.05);
    border-bottom: 1px solid rgba(27, 38, 59, 0.05);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-sm);
  }
  @media(min-width: 768px) {
    .trust-grid { grid-template-columns: repeat(4, 1fr); }
  }
  
  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--spacing-sm);
  }
  .trust-icon {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .trust-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-accent);
  }
</style>

<div class="trust-banner-wrapper">
  <div class="container trust-grid">
    {%- for block in section.blocks -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <div class="trust-icon">{{ block.settings.icon }}</div>
        <div class="trust-title">{{ block.settings.title }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji/Icon", "default": "✨" },
        { "type": "text", "id": "title", "label": "Title", "default": "Premium Quality" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
