{% comment %}
  Global Header Section
{% endcomment %}

{{ 'global.css' | asset_url | stylesheet_tag }}
<style>
  /* Sticky Refinement */
  .header-wrapper.is-sticky {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 30px rgba(27, 38, 59, 0.05);
  }
  
  .header-inner {
    height: 80px;
    transition: height 0.3s ease;
  }
  
  .is-sticky .header-inner {
    height: 64px;
  }

  /* Logo + Wordmark Alignment */
  .header-logo-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand-logo-svg {
    width: 32px;
    height: 32px;
    fill: var(--color-accent);
  }

  .brand-wordmark {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--color-accent);
    text-transform: uppercase;
  }
</style>

<header class="header-wrapper glass-panel">
  <div class="container header-inner flex items-center justify-between">
    
    <!-- Markets Selector (Desktop) -->
    <div class="market-selectors items-center">
      {% form 'localization' %}
        <select name="country_code" class="localization-select">
          {% for country in localization.available_countries %}
            <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
              {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
            </option>
          {% endfor %}
        </select>
        
        <select name="language_code" class="localization-select">
          {% for language in localization.available_languages %}
            <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
              {{ language.endonym_name | capitalize }}
            </option>
          {% endfor %}
        </select>
      {% endform %}
    </div>

    <!-- Logo + Wordmark -->
    <a href="{{ routes.root_url }}" class="header-logo-wrapper">
      <svg class="brand-logo-svg" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 2L4 34H12L20 18L28 34H36L20 2Z" />
        <rect x="16" y="24" width="8" height="2" />
      </svg>
      <span class="brand-wordmark">{{ shop.name }}</span>
    </a>

    <!-- Dynamic Main Navigation -->
    <nav class="header-nav hidden-mobile">
      <ul style="display:flex; list-style:none; gap:24px; margin:0; padding:0; font-family:var(--font-heading); font-size:0.95rem; font-weight:600; color:var(--color-accent);">
        {%- if linklists[section.settings.menu].links != blank -%}
          {%- for link in linklists[section.settings.menu].links -%}
            <li><a href="{{ link.url }}" style="text-decoration:none;">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/" style="text-decoration:none;">Home</a></li>
          <li><a href="/collections/all" style="text-decoration:none;">Shop All</a></li>
          <li><a href="/collections" style="text-decoration:none;">Collections</a></li>
          <li><a href="/pages/contact" style="text-decoration:none;">Contact</a></li>
        {%- endif -%}
      </ul>
    </nav>

    <!-- Predictive Search -->
    <div class="predictive-search hidden-mobile">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="search" name="q" placeholder="Search premium products..." class="search-input">
      </form>
    </div>

    <!-- Icons / Cart -->
    <div class="header-icons flex items-center gap-md">
      <!-- Search mobile trigger -->
      <button class="icon-btn search-trigger-mobile show-mobile">
        {% render 'icon-search' %}
      </button>
      
      <!-- User Account -->
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="icon-btn">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}
      
      <!-- Side Cart Trigger -->
      <a href="javascript:void(0)" class="icon-btn cart-trigger js-cart-trigger" id="cart-icon-bubble">
        {% render 'icon-cart' %}
        <div class="cart-count-bubble">
          {%- if cart.item_count > 0 -%}
            <span aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </div>
      </a>
      
      <!-- Mobile Hamburger -->
      <button class="icon-btn hamburger-trigger show-mobile">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Global Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo Width"
    }
  ]
}
{% endschema %}
