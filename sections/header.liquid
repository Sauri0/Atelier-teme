{% comment %}
  Global Header Section
{% endcomment %}

{{ 'global.css' | asset_url | stylesheet_tag }}
<style>
  /* Sticky Refinement */
  .header-wrapper.is-sticky {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 30px rgba(27, 38, 59, 0.05);
  }
  
  .header-inner {
    height: 80px;
    transition: height 0.3s ease;
  }
  
  .is-sticky .header-inner {
    height: 64px;
  }

  /* Elite Minimalist Selectors */
  .selector-options {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .selector-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-light);
    transition: var(--transition-base);
  }

  .selector-btn:hover, .selector-btn.active {
    color: var(--color-primary);
  }

  .selector-sep {
    color: rgba(27, 38, 59, 0.2);
    font-weight: 300;
  }

  .icon-btn svg {
    max-height: 20px;
    width: auto;
  }
</style>

<header class="header-wrapper glass-panel">
  <div class="container header-inner flex items-center justify-between">
    
    <!-- Elite Minimalist Selectors -->
    <div class="market-selectors flex hide-mobile">
      <localization-form>
        {%- form 'localization', id: 'HeaderLanguageForm' -%}
          <div class="elite-selector">
            <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
            <div class="selector-options">
              <button type="submit" name="language_code" value="es" class="selector-btn {% if localization.language.iso_code == 'es' %}active{% endif %}">ESP</button>
              <span class="selector-sep">/</span>
              <button type="submit" name="language_code" value="en" class="selector-btn {% if localization.language.iso_code == 'en' %}active{% endif %}">EN</button>
            </div>
          </div>
        {%- endform -%}
      </localization-form>

      <localization-form>
        {%- form 'localization', id: 'HeaderCurrencyForm' -%}
          <div class="elite-selector" style="margin-left: 16px;">
            <input type="hidden" name="currency_code" value="{{ localization.country.currency.iso_code }}">
            <div class="selector-options">
              <button type="submit" name="country_code" value="AR" class="selector-btn {% if localization.country.currency.iso_code == 'ARS' %}active{% endif %}">ARS</button>
              <span class="selector-sep">/</span>
              <button type="submit" name="country_code" value="US" class="selector-btn {% if localization.country.currency.iso_code == 'USD' %}active{% endif %}">USD</button>
            </div>
          </div>
        {%- endform -%}
      </localization-form>
    </div>

    <!-- Logo + Wordmark -->
    <a href="/" class="header-logo-wrapper">
      <svg class="brand-logo-svg" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 2L4 34H12L20 18L28 34H36L20 2Z" />
        <rect x="16" y="24" width="8" height="2" />
      </svg>
      <span class="brand-wordmark">{{ shop.name }}</span>
    </a>

    <!-- Dynamic Main Navigation -->
    <nav class="header-nav hidden-mobile">
      <ul style="display:flex; list-style:none; gap:28px; margin:0; padding:0; font-family:var(--font-heading); font-size:0.85rem; font-weight:700; color:var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;">
        <li><a href="/" style="text-decoration:none;">Home</a></li>
        <li><a href="/collections/all" style="text-decoration:none;">Shop All</a></li>
        <li><a href="/collections/featured" style="text-decoration:none;">Essentials</a></li>
      </ul>
    </nav>

    <!-- Icons / Cart -->
    <div class="header-icons flex items-center gap-md">
      <a href="/search" class="icon-btn search-trigger show-desktop">
        {% render 'icon-search' %}
      </a>
      
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_login_url }}" class="icon-btn">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}
      
      <a href="javascript:void(0)" class="icon-btn cart-trigger js-cart-trigger" id="cart-icon-bubble">
        {% render 'icon-cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="cart-count-bubble">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      
      <button class="icon-btn hamburger-trigger show-mobile">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Global Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo Width"
    }
  ]
}
{% endschema %}
