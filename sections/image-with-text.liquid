{% comment %}
  Atelier Brand Story - Image with Text
{% endcomment %}

<style>
  .story-wrapper { margin: var(--spacing-xl) 0; }
  .story-grid { display: flex; flex-direction: column; gap: 0; }
  @media(min-width: 1024px) {
    .story-grid { flex-direction: row; align-items: center; }
    .story-image-col { width: 50%; }
    .story-text-col { width: 50%; padding: var(--spacing-xl) 8%; }
  }
  
  .story-img { width: 100%; aspect-ratio: 4/5; object-fit: cover; border-radius: 0; }
  @media(min-width: 1024px) { .story-img { border-radius: var(--border-radius); } }
  
  .story-text-col { padding: var(--spacing-lg) var(--spacing-md); text-align: left; }
  .story-sub { font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); font-size: 0.85rem; margin-bottom: 12px; }
  .story-title { font-size: clamp(2rem, 3vw, 3rem); margin-bottom: 24px; color: var(--color-accent); line-height: 1.1; }
  .story-desc { font-size: 1.1rem; color: var(--color-text-light); margin-bottom: 32px; max-width: 500px; }
</style>

<div class="container story-wrapper">
  <div class="story-grid">
    <div class="story-image-col">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image }}" class="story-img" loading="lazy" alt="Brand Story">
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1542295669297-4d352b042bce?q=80&w=1000&auto=format&fit=crop" class="story-img" loading="lazy" alt="Atelier Craft">
      {%- endif -%}
    </div>
    <div class="story-text-col">
      <div class="story-sub">{{ section.settings.subheading }}</div>
      <h2 class="story-title">{{ section.settings.title }}</h2>
      <p class="story-desc">{{ section.settings.text }}</p>
      <a href="{{ section.settings.link }}" class="btn btn-primary">{{ section.settings.btn_text }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with Text (Story)",
  "settings": [
    { "type": "text", "id": "image", "label": "External Image URL", "default": "https://images.unsplash.com/photo-1620799139834-6b8f844fbe61?q=80&w=1000&auto=format&fit=crop" },
    { "type": "text", "id": "subheading", "default": "Our Philosophy" },
    { "type": "text", "id": "title", "default": "Minimalism Meets Exceptional Quality" },
    { "type": "textarea", "id": "text", "default": "We believe in creating pieces that stand the test of time. Sourcing the finest materials globally to craft a standard of luxury that speaks for itself." },
    { "type": "text", "id": "btn_text", "default": "Discover Our Craft" },
    { "type": "url", "id": "link" }
  ],
  "presets": [ { "name": "Brand Story" } ]
}
{% endschema %}
