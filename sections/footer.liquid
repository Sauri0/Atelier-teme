{% comment %}
  Global Footer - 4 Columns, Navy Green (#1B263B)
{% endcomment %}

<style>
  .footer-wrapper {
    background-color: var(--color-accent); /* Navy Green #1B263B */
    color: #FFFFFF;
    padding: var(--spacing-xl) 0 var(--spacing-md) 0;
    margin-top: var(--spacing-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 2fr;
    }
  }

  .footer-col h4 {
    color: #FFFFFF;
    font-family: var(--font-heading);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-col p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .footer-nav {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: var(--transition-base);
  }

  .footer-nav a:hover {
    color: var(--color-primary); /* Aqua Green */
    padding-left: 4px; /* Micro-interaction */
  }

  /* Newsletter Minimalist */
  .footer-newsletter form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .newsletter-input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 12px 16px;
    border-radius: var(--border-radius);
    color: #FFFFFF;
    font-family: var(--font-body);
  }
  
  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .btn-newsletter {
    background-color: var(--color-primary);
    color: #FFFFFF;
    padding: 12px;
    border: none;
    border-radius: var(--border-radius);
    font-family: var(--font-heading);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-base);
  }

  .btn-newsletter:hover {
    background-color: #178a84;
  }

  /* Footer Bottom Row */
  .footer-bottom {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-copyright {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
  }

  .payment-icons {
    display: flex;
    gap: 8px;
  }

  .payment-icon {
    width: 38px;
    height: 24px;
    background: #FFFFFF;
    border-radius: 4px;
    padding: 2px 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .payment-icon svg {
    max-width: 100%;
    max-height: 100%;
  }
</style>

<footer class="footer-wrapper">
  <div class="container">
    <div class="footer-grid">
      
      <!-- Col 1: Brand & Logo -->
      <div class="footer-col">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 150 }}" alt="{{ shop.name }}" loading="lazy" style="filter: brightness(0) invert(1); margin-bottom: 24px;">
        {%- else -%}
          <h2 style="color: #FFF; margin-bottom: 24px;">{{ shop.name }}</h2>
        {%- endif -%}
        <p>{{ section.settings.brand_text | escape }}</p>
      </div>

      <!-- Col 2: Shop Nav -->
      <div class="footer-col">
        <h4>{{ section.settings.linklist_1_title | escape }}</h4>
        <ul class="footer-nav">
          {%- for link in linklists[section.settings.linklist_1].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Col 3: Support Nav -->
      <div class="footer-col">
        <h4>{{ section.settings.linklist_2_title | escape }}</h4>
        <ul class="footer-nav">
          {%- for link in linklists[section.settings.linklist_2].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Col 4: Newsletter -->
      <div class="footer-col footer-newsletter">
        <h4>Exclusive Access</h4>
        <p style="margin-bottom: 16px;">Subscribe to receive updates, access to exclusive deals, and more.</p>
        <form method="post" action="/contact#contact_form" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="customer">
          <input type="email" name="contact[email]" class="newsletter-input" placeholder="Enter your email address" required>
          <button type="submit" class="btn btn-primary btn-newsletter">Subscribe</button>
        </form>
      </div>

    </div>

    <!-- Bottom Compliance Row -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; {{ 'now' | date: "%Y" }}, {{ shop.name | link_to: '/' }}. All rights reserved.
      </div>
      <div class="payment-icons">
        {%- for type in shop.enabled_payment_types -%}
          <span class="payment-icon">
             {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          </span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Global Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo (Auto converts to white)"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand Description",
      "default": "Elevating your daily experience with premium materials and unparalleled design."
    },
    {
      "type": "link_list",
      "id": "linklist_1",
      "label": "Shop Menu"
    },
    {
      "type": "text",
      "id": "linklist_1_title",
      "label": "Shop Menu Title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "linklist_2",
      "label": "Support Menu"
    },
    {
      "type": "text",
      "id": "linklist_2_title",
      "label": "Support Menu Title",
      "default": "Information"
    }
  ]
}
{% endschema %}
