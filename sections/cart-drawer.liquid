{% comment %}
  Atelier v2.2 Emergency Sync
  Cart Drawer Section - AJAX, Glassmorphism, Free Shipping Bar & Accessibility Trap
{% endcomment %}

<style>
  .cart-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 480px;
    height: 100vh;
    height: 100dvh;
    z-index: 999;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    
    /* Glassmorphism */
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: -10px 0 40px rgba(27, 38, 59, 0.1);
  }

  /* Open States */
  .cart-drawer.is-open {
    transform: translateX(0);
  }
  .cart-drawer.is-open ~ .cart-overlay {
    opacity: 1;
    visibility: visible;
  }

  .cart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md);
    border-bottom: 1px solid rgba(27, 38, 59, 0.1);
  }

  .cart-title {
    font-family: var(--font-heading);
    color: var(--color-accent);
    font-size: 1.25rem;
    margin: 0;
  }

  .cart-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    color: var(--color-text-main);
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Free Shipping Bar */
  .shipping-progress-container {
    padding: var(--spacing-md);
    background: var(--color-surface);
  }

  .shipping-message {
    font-family: var(--font-body);
    font-size: 0.85rem;
    margin-bottom: 8px;
    text-align: center;
    color: var(--color-text-main);
  }

  .progress-bg {
    width: 100%;
    height: 8px;
    background: #E1E3E4;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary); /* Aqua Green */
    transition: width 0.4s ease;
  }

  /* Body Items */
  .cart-body {
    flex-grow: 1;
    overflow-y: auto;
    padding: var(--spacing-md);
  }

  .cart-empty {
    text-align: center;
    padding: var(--spacing-xl) 0;
    color: var(--color-text-light);
  }

  /* Cart Footer */
  .cart-footer {
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(27, 38, 59, 0.1);
    position: sticky;
    bottom: 0;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.08);
  }

  .cart-subtotal {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-accent);
    margin-bottom: var(--spacing-sm);
  }

  .cart-checkout-btn {
    width: 100%;
    padding: 16px;
    background: var(--color-accent); /* Navy Green #1B263B */
    color: white;
    border: none;
    border-radius: var(--border-radius);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    text-align: center;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .secure-payment-icons {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  .secure-icon {
    height: 20px;
    fill: var(--color-accent); /* Navy Green tinted icons */
    opacity: 0.8;
  }
</style>

<div id="CartDrawer" class="cart-drawer" aria-modal="true" role="dialog" tabindex="-1" aria-labelledby="CartTitle">
  <div class="cart-header">
    <h2 id="CartTitle" class="cart-title">Your Cart</h2>
    <button class="cart-close-btn" aria-label="Close cart" id="CloseCartBtn">
      &times;
    </button>
  </div>

  <!-- Dynamic Shipping Bar -->
  <div class="shipping-progress-container" id="CartShippingBar">
    <!-- Rendered via JS based on cart total -->
  </div>

  <div class="cart-body" id="CartDrawerBody">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-item" style="display:flex; gap:16px; margin-bottom:24px; position: relative;" data-key="{{ item.key }}">
          <div style="flex-shrink:0;">
            <img src="{{ item.image | image_url: width: 140 }}" width="90" height="110" style="object-fit:cover; border-radius:8px; background:var(--color-surface);">
          </div>
          <div style="flex-grow:1; display: flex; flex-direction: column; justify-content: space-between;">
            <div>
              <div style="font-weight:600; font-family:var(--font-heading); color:var(--color-accent); font-size:1rem; margin-bottom:4px;">{{ item.product.title }}</div>
              {%- unless item.product.has_only_default_variant -%}
                <div style="font-size:0.8rem; color:var(--color-text-light); margin-bottom:8px;">{{ item.variant.title }}</div>
              {%- endunless -%}
              <div style="color:var(--color-accent); font-weight:700;">{{ item.final_line_price | money }}</div>
            </div>
            
            <div style="display:flex; align-items:center; gap:12px; margin-top:12px;">
              <div class="quantity-selector" style="display:flex; align-items:center; border:1px solid rgba(27,38,59,0.1); border-radius:20px; padding:4px 12px; gap:12px;">
                <button class="js-qty-btn" data-action="minus" data-key="{{ item.key }}" style="background:none; border:none; cursor:pointer; font-size:1.2rem; padding:0 4px;">-</button>
                <span style="font-size:0.9rem; font-weight:600; min-width:12px; text-align:center;">{{ item.quantity }}</span>
                <button class="js-qty-btn" data-action="plus" data-key="{{ item.key }}" style="background:none; border:none; cursor:pointer; font-size:1.2rem; padding:0 4px;">+</button>
              </div>
              <button class="js-remove" data-key="{{ item.key }}" style="border:none; background:none; color:var(--color-text-light); text-decoration:underline; cursor:pointer; font-size:0.8rem;">Remove</button>
            </div>
          </div>
        </div>
      {%- endfor -%}
      
      <!-- Call the Upsell Engine -->
      {% render 'cart-upsell-engine' %}

    {%- else -%}
      <div class="cart-empty">
        <p>Tu selección está vacía. Comienza a explorar nuestro Atelier.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary" id="ContinueShoppingBtn">Explorar Todo</a>
      </div>
    {%- endif -%}
  </div>

  <div class="cart-footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span id="CartSubtotal">{{ cart.total_price | money }}</span>
    </div>
    <form action="{{ routes.cart_url }}" method="post" id="cart">
      <button type="submit" name="checkout" class="cart-checkout-btn">Secure Checkout</button>
    </form>
    <div class="secure-payment-icons">
      <!-- Minimalist static SVGs via external or placeholder -->
      <span style="font-size:0.8rem; color:var(--color-accent); font-family:var(--font-body);">🔒 Encrypted SSL Checkout • Stripe • PayPal</span>
    </div>
  </div>
</div>
<div class="cart-overlay" id="CartOverlay"></div>

<script>
  class CartDrawer {
    constructor() {
      this.drawer = document.getElementById('CartDrawer');
      this.overlay = document.getElementById('CartOverlay');
      this.closeBtn = document.getElementById('CloseCartBtn');
      this.shippingThreshold = {{ section.settings.free_shipping_threshold | times: 100 | default: 10000 }}; // e.g. 100 USD
      this.cartTotal = {{ cart.total_price }};
      this.currencySymbol = '{{ cart.currency.symbol }}';
      
      this.bindEvents();
      this.initShippingBar();
      this.checkLocalStorage();
    }

    bindEvents() {
      this.closeBtn.addEventListener('click', () => this.close());
      this.overlay.addEventListener('click', () => this.close());
      
      // Global updated trigger
      document.addEventListener('cart:updated', () => this.fetchCartAndRender());
      
      // Delegate Item Actions (Qty and Remove)
      this.drawer.addEventListener('click', (e) => {
        const qtyBtn = e.target.closest('.js-qty-btn');
        if (qtyBtn) {
          const action = qtyBtn.dataset.action;
          const key = qtyBtn.dataset.key;
          const currentQty = parseInt(qtyBtn.parentElement.querySelector('span').innerText);
          const newQty = action === 'plus' ? currentQty + 1 : currentQty - 1;
          this.updateQuantity(key, newQty);
          return;
        }

        const removeBtn = e.target.closest('.js-remove');
        if (removeBtn) {
          this.updateQuantity(removeBtn.dataset.key, 0);
          return;
        }
        
        const quickAddBtn = e.target.closest('.js-quick-add');
        if (quickAddBtn) {
          this.quickAdd(quickAddBtn.dataset.variantId);
        }
      });
      
      this.drawer.addEventListener('keydown', (e) => this.trapFocus(e));
    }

    setLoading(state) {
      if (state) {
        this.drawer.style.opacity = '0.6';
        this.drawer.style.pointerEvents = 'none';
      } else {
        this.drawer.style.opacity = '1';
        this.drawer.style.pointerEvents = 'all';
      }
    }

    updateQuantity(key, quantity) {
      this.setLoading(true);
      fetch(window.Shopify.routes.root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity })
      })
      .then(r => r.json())
      .then(() => this.fetchCartAndRender())
      .finally(() => this.setLoading(false));
    }

    fetchCartAndRender() {
      this.setLoading(true);
      // Section Rendering API: Fetch the new HTML for this specific section
      fetch(`${window.location.pathname}?sections=cart-drawer`)
        .then(r => r.json())
        .then(response => {
          const html = new DOMParser().parseFromString(response['cart-drawer'], 'text/html');
          const newBody = html.getElementById('CartDrawerBody').innerHTML;
          const newFooter = html.querySelector('.cart-footer').innerHTML;
          const newCount = html.getElementById('cart-icon-bubble')?.innerHTML;

          document.getElementById('CartDrawerBody').innerHTML = newBody;
          document.querySelector('.cart-footer').innerHTML = newFooter;
          if (newCount) {
             const iconBubble = document.getElementById('cart-icon-bubble');
             if (iconBubble) iconBubble.innerHTML = newCount;
          }
          
          this.initShippingBar();
          if(!this.drawer.classList.contains('is-open')) this.open();
        })
        .catch(e => console.error("Cart render error:", e))
        .finally(() => this.setLoading(false));
    }

    initShippingBar() {
      const container = document.getElementById('CartShippingBar');
      let remainder = this.shippingThreshold - this.cartTotal;
      let percentage = Math.min((this.cartTotal / this.shippingThreshold) * 100, 100);
      
      let message = percentage >= 100 
        ? "🎉 You've unlocked <strong>Free Shipping!</strong>" 
        : `You are <strong>${Shopify.formatMoney(remainder, this.currencySymbol + '{{amount}}')}</strong> away from Free Shipping!`;
      
      container.innerHTML = `
        <div class="shipping-message">${message}</div>
        <div class="progress-bg">
          <div class="progress-fill" style="width: ${percentage}%"></div>
        </div>
      `;
    }

    trapFocus(e) {
      const focusable = this.drawer.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.key === 'Tab') {
        if (e.shiftKey && document.activeElement === first) {
          last.focus();
          e.preventDefault();
        } else if (!e.shiftKey && document.activeElement === last) {
          first.focus();
          e.preventDefault();
        }
      } else if (e.key === 'Escape') {
        this.close();
      }
    }
  }

  // Basic formatMoney polyfill if not injected by theme
  window.Shopify = window.Shopify || {};
  Shopify.formatMoney = Shopify.formatMoney || function(cents, format) {
    if (typeof cents == 'string') { cents = cents.replace('.',''); }
    var value = '';
    var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
    var formatString = (format || this.money_format);

    function defaultOption(opt, def) { return (typeof opt == 'undefined' ? def : opt); }
    function formatWithDelimiters(number, precision, thousands, decimal) {
      precision = defaultOption(precision, 2);
      thousands = defaultOption(thousands, ',');
      decimal   = defaultOption(decimal, '.');

      if (isNaN(number) || number == null) { return 0; }
      number = (number/100.0).toFixed(precision);

      var parts   = number.split('.'),
          dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
          cents   = parts[1] ? (decimal + parts[1]) : '';
      return dollars + cents;
    }

    value = formatWithDelimiters(cents, 2);
    return formatString.replace(placeholderRegex, value);
  };

  document.addEventListener('DOMContentLoaded', () => {
    window.themeCart = new CartDrawer();
  });
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free Shipping Threshold (Amount)",
      "default": 100,
      "info": "Set the amount without currency symbols. E.g. 100 for $100."
    }
  ]
}
{% endschema %}
