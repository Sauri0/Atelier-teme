{% comment %}
  Featured Products Section - Fallbacks to Luxury Hardcoded Cards if Empty
{% endcomment %}

<style>
  .featured-wrapper { margin: var(--spacing-xl) auto; }
  .section-title { text-align: center; margin-bottom: var(--spacing-lg); }
  .product-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-md); }
  @media(min-width: 1024px) { .product-grid { grid-template-columns: repeat(4, 1fr); } }
  
  .product-card {
    background: var(--color-surface);
    border-radius: var(--border-radius);
    padding: var(--spacing-sm);
    text-align: center;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    border: 1px solid transparent;
  }
  .product-card:hover { 
    transform: translateY(-8px); 
    box-shadow: var(--shadow-hover);
    border-color: rgba(32, 178, 170, 0.1); 
  }
  .product-card:hover .product-img {
    transform: scale(1.05);
  }
  .product-img-wrapper {
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .product-img { 
    width: 100%; 
    aspect-ratio: 3/4; 
    object-fit: cover; 
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .product-title { font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-accent); font-weight: 600; margin-bottom: 4px; }
  .product-price { font-family: var(--font-body); color: var(--color-primary); font-weight: 500; margin-bottom: 12px; }
  .btn-quick-add { width: 100%; }
</style>

<div class="container featured-wrapper animate-fade-up">
  <h2 class="section-title">{{ section.settings.title }}</h2>
  
  <div class="product-grid">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <!-- Normal Product Render -->
      {%- endfor -%}
    {%- else -%}
      <!-- Luxury Hardcoded Fallbacks -->
      <div class="product-card">
        <div class="product-img-wrapper">
          <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=600&auto=format&fit=crop" class="product-img" loading="lazy">
        </div>
        <div class="product-title">Atelier Signature Watch</div>
        <div class="product-price">$2,450.00</div>
        <button class="btn btn-primary btn-quick-add js-cart-trigger">Pre-Order</button>
      </div>
      <div class="product-card">
        <img src="https://images.unsplash.com/photo-1590845947698-8924d7409b56?q=80&w=600&auto=format&fit=crop" class="product-img" loading="lazy">
        <div class="product-title">Classic Leather Tote</div>
        <div class="product-price">$890.00</div>
        <button class="btn btn-primary btn-quick-add js-cart-trigger">Add to Cart</button>
      </div>
      <div class="product-card">
        <img src="https://images.unsplash.com/photo-1611930022073-b7a4ba5fcccd?q=80&w=600&auto=format&fit=crop" class="product-img" loading="lazy">
        <div class="product-title">Onyx Minimalist Ring</div>
        <div class="product-price">$450.00</div>
        <button class="btn btn-primary btn-quick-add js-cart-trigger">Add to Cart</button>
      </div>
      <div class="product-card">
        <img src="https://images.unsplash.com/photo-1548036328-c9fa89d128fa?q=80&w=600&auto=format&fit=crop" class="product-img" loading="lazy">
        <div class="product-title">Premium Cashmere Scarf</div>
        <div class="product-price">$280.00</div>
        <button class="btn btn-primary btn-quick-add js-cart-trigger">Add to Cart</button>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Selection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Cards to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
