{% comment %}
  Featured Products / Best Sellers Carousel
{% endcomment %}

<style>
  .featured-products-section {
    padding: var(--spacing-xl) 0;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .products-grid {
    display: flex;
    gap: var(--spacing-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    padding-bottom: var(--spacing-md);
  }
  
  .products-grid::-webkit-scrollbar {
    display: none; /* Safari/Chrome */
  }

  @media (min-width: 1024px) {
    .products-grid {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      overflow-x: visible;
    }
  }

  /* Product Card - The Digital Atelier Style */
  .product-card {
    flex: 0 0 75vw; /* Mobile carousel width */
    scroll-snap-align: start;
    background: var(--color-surface);
    border-radius: var(--border-radius);
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    position: relative;
    box-shadow: var(--shadow-subtle);
    transition: var(--transition-base);
  }

  @media (min-width: 768px) {
    .product-card {
      flex: 1; /* Grid override */
    }
  }

  .product-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .product-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.2;
    background: var(--color-bg);
    border-radius: 8px;
    overflow: hidden;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  /* Liquid Logic Badges */
  .badges-container {
    position: absolute;
    top: 8px;
    left: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 2;
  }

  .badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-heading);
    text-transform: uppercase;
  }

  .badge-sale {
    background-color: var(--color-accent); /* Navy Green */
    color: white;
  }

  .badge-new {
    background-color: var(--color-primary); /* Aqua Green */
    color: white;
  }

  .product-info {
    text-align: left;
    flex-grow: 1;
  }

  .product-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 4px;
    color: var(--color-text-main);
  }

  .product-price {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-accent);
  }

  .compare-price {
    text-decoration: line-through;
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-left: 8px;
  }

  /* Thumb-friendly Quick Add Button */
  .quick-add-btn {
    width: 100%;
    padding: 14px;
    margin-top: auto;
    background: var(--color-surface);
    color: var(--color-accent);
    border: 1px solid rgba(27, 38, 59, 0.2);
    border-radius: var(--border-radius);
    font-family: var(--font-heading);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-base);
  }

  .quick-add-btn:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }
</style>

<div class="featured-products-section">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | escape }}</h2>
    </div>

    <div class="products-grid">
      {%- assign collection = section.settings.collection -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        
        <div class="product-card">
          <a href="{{ product.url }}" class="product-image-wrapper">
            <div class="badges-container">
              {%- if product.compare_at_price > product.price -%}
                <span class="badge badge-sale">Sale</span>
              {%- endif -%}
              
              {%- assign date_created = product.created_at | date: '%s' -%}
              {%- assign now = 'now' | date: '%s' -%}
              {%- assign diff_seconds = now | minus: date_created -%}
              {%- if diff_seconds < 2592000 -%} <!-- Less than 30 days old -->
                <span class="badge badge-new">New</span>
              {%- endif -%}
            </div>
            
            <img 
              src="{{ product.featured_image | image_url: width: 600 }}" 
              alt="{{ product.title | escape }}" 
              class="product-image"
              loading="lazy"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
            >
          </a>
          
          <div class="product-info">
            <h3 class="product-title">
              <a href="{{ product.url }}">{{ product.title | escape }}</a>
            </h3>
            <div class="product-price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <span class="compare-price">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
          
          <!-- Quick Add Form -->
          <form method="post" action="/cart/add" class="quick-add-form">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" class="quick-add-btn">
              Quick Add
            </button>
          </form>

        </div>
        
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="product-card">
            <div class="product-image-wrapper">
               {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-info">
              <h3 class="product-title">Example Product Title</h3>
              <div class="product-price">{{ 1999 | money }}</div>
            </div>
            <button disabled class="quick-add-btn">Quick Add</button>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Best Sellers",
      "label": "Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "settings": {
        "title": "Best Sellers"
      }
    }
  ]
}
{% endschema %}
