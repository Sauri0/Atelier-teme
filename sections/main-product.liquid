{% comment %}
  Main Product Section - Conversion Engine
{% endcomment %}

<style>
  .product-section {
    padding: var(--spacing-xl) 0;
  }
  
  .product-layout {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  @media (min-width: 1024px) {
    .product-layout {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  /* MEDIA GALLERY (Left Col) */
  .product-media-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    opacity: 0;
    animation: fadeUp 1s ease 0.2s forwards;
  }

  @media (min-width: 1024px) {
    .product-media-wrapper {
      width: 60%;
      position: sticky;
      top: 100px;
    }
  }

  .main-image-container {
    background: var(--color-surface);
    border-radius: var(--border-radius);
    overflow: hidden;
    cursor: zoom-in;
    aspect-ratio: 4/5;
    position: relative;
  }

  .main-image-container img, .main-image-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* PRODUCT INFO (Right Col) */
  .product-info-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (min-width: 1024px) {
    .product-info-wrapper {
      width: 40%;
      max-width: 480px;
    }
  }

  .product-title {
    font-size: clamp(2rem, 3vw, 2.5rem);
    margin-bottom: var(--spacing-sm);
  }

  .product-price-wrapper {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .price-regular { color: var(--color-accent); }
  .price-compare { 
    text-decoration: line-through; 
    color: var(--color-text-light); 
    font-size: 1.1rem;
    font-weight: 500;
  }

  .savings-badge {
    background-color: var(--color-primary);
    color: white;
    padding: 4px 12px;
    border-radius: 16px;
    font-size: 0.9rem;
    margin-left: var(--spacing-sm);
  }

  .tax-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-weight: 400;
    display: block;
    margin-top: 4px;
  }

  /* SWATCHES (Pills & Colors) */
  .variant-group {
    margin-top: var(--spacing-md);
    border: none;
  }

  .variant-label {
    font-family: var(--font-heading);
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
  }

  .swatches-container {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .swatch-input {
    display: none;
  }

  /* Pill Swatch (Size) */
  .swatch-label-pill {
    display: inline-block;
    padding: 10px 20px;
    border: 1px solid rgba(27, 38, 59, 0.2);
    border-radius: 20px;
    cursor: pointer;
    font-family: var(--font-body);
    transition: var(--transition-base);
  }

  .swatch-input:checked + .swatch-label-pill {
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  /* Color Swatch (Circular) */
  .swatch-label-color {
    display: inline-block;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);
  }

  .swatch-input:checked + .swatch-label-color {
    border-color: var(--color-accent);
    transform: scale(1.1);
  }

  /* Main Add to Cart */
  .main-atc-button {
    width: 100%;
    padding: 18px;
    font-size: 1.1rem;
    margin-top: var(--spacing-lg);
  }

  .main-atc-button.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  /* Accordions */
  .product-details-accordion {
    margin-top: var(--spacing-lg);
    border-top: 1px solid rgba(27, 38, 59, 0.05);
  }

  .details-item {
    border-bottom: 1px solid rgba(27, 38, 59, 0.05);
  }

  .details-summary {
    list-style: none;
    padding: 20px 0;
    cursor: pointer;
    font-family: var(--font-heading);
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .details-summary::-webkit-details-marker { display: none; }

  .details-summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 300;
    transition: transform 0.3s ease;
  }

  details[open] .details-summary::after {
    transform: rotate(45deg);
  }

  .details-content {
    padding-bottom: 20px;
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Trust Badges v2 (Vector) */
  .trust-badges-v2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: var(--spacing-xl);
    padding: 24px;
    background: var(--color-surface);
    border-radius: var(--border-radius);
  }

  .badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .badge-icon {
    width: 24px;
    height: 24px;
    stroke: var(--color-primary);
    stroke-width: 1.5px;
  }

  .badge-text {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }
</style>

<section class="product-section container animate-fade-up">
  <div class="product-layout">
    
    <!-- LEFT COLUMN: Media -->
    <div class="product-media-wrapper">
      {%- for media in product.media -%}
        <div class="main-image-container">
          {%- if media.media_type == 'image' -%}
            <img 
              src="{{ media | image_url: width: 1200 }}" 
              alt="{{ media.preview_image.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ media.preview_image.width }}"
              height="{{ media.preview_image.height }}"
            >
          {%- elsif media.media_type == 'video' -%}
            {{ media | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- RIGHT COLUMN: sticky info -->
    <div class="product-info-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'title' -%}
            <h1 class="product-title" {{ block.shopify_attributes }}>{{ product.title | escape }}</h1>
          
          {%- when 'price' -%}
            <div class="product-price-wrapper" {{ block.shopify_attributes }}>
              <span class="price-regular">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="price-compare">{{ product.compare_at_price | money }}</span>
                {%- assign saving_percentage = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                <span class="savings-badge">Save {{ saving_percentage }}%</span>
              {%- endif -%}
            </div>
            <span class="tax-label">Tax Included. Shipping calculated at checkout.</span>
            
          {%- when 'variant_picker' -%}
            {%- unless product.has_only_default_variant -%}
              <div class="product-variants" {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                  <fieldset class="variant-group">
                    <legend class="variant-label">{{ option.name }}</legend>
                    <div class="swatches-container">
                      {%- assign is_color = false -%}
                      {%- assign option_name_down = option.name | downcase -%}
                      {%- if option_name_down contains 'color' or option_name_down contains 'colour' -%}
                        {%- assign is_color = true -%}
                      {%- endif -%}

                      {%- for value in option.values -%}
                        <input 
                          type="radio" 
                          class="swatch-input" 
                          id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          form="product-form-{{ section.id }}"
                          {% if option.selected_value == value %}checked{% endif %}
                        >
                        {%- if is_color -%}
                          <label 
                            class="swatch-label-color" 
                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                            style="background-color: {{ value | handleize }}; background-image: url({{ value | handleize | append: '.png' | asset_url }});"
                            title="{{ value }}"
                          >
                            <span class="visually-hidden">{{ value }}</span>
                          </label>
                        {%- else -%}
                          <label 
                            class="swatch-label-pill" 
                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          >
                            {{ value }}
                          </label>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              </div>
            {%- endunless -%}

          {%- when 'buy_buttons' -%}
            <div {{ block.shopify_attributes }}>
              <form method="post" action="/cart/add" id="product-form-{{ section.id }}" accept-charset="UTF-8" class="form" enctype="multipart/form-data">
                <input type="hidden" name="form_type" value="product">
                <input type="hidden" name="utf8" value="✓">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                
                <button 
                  type="submit" 
                  name="add" 
                  class="btn btn-primary main-atc-button"
                  id="main-atc-submit"
                  {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                >
                  {%- if product.selected_or_first_available_variant.available -%}
                    Add to Cart
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </button>
              </form>
              
              <!-- Immediate Friciton-Reduction Widget -->
              <div style="margin-top: 16px;">
                {% render 'product-shipping-widget' %}
              </div>
            </div>
            
          {%- when 'shipping_widget' -%}
            <div {{ block.shopify_attributes }}>
              {% render 'product-shipping-widget' %}
            </div>

          {%- when 'description' -%}
            <div class="product-details-accordion" {{ block.shopify_attributes }}>
              <details class="details-item" open>
                <summary class="details-summary">Description</summary>
                <div class="details-content">
                  {{ product.description }}
                </div>
              </details>
              
              <details class="details-item">
                <summary class="details-summary">Materials & Care</summary>
                <div class="details-content">
                  <p>Hand-selected premium materials. Professional dry clean only. Handle with the utmost care to preserve the longevity of the exquisite craftsmanship.</p>
                </div>
              </details>

              <details class="details-item">
                <summary class="details-summary">Shipping & Returns</summary>
                <div class="details-content">
                  <p>Complimentary global shipping on all orders. Returns accepted within 14 days of delivery in original condition and packaging.</p>
                </div>
              </details>
            </div>
            {% comment %} Atelier v2.2 Final Emergency Sync Hook {% endcomment %}

            <!-- Trust Badges v2 -->
            <div class="trust-badges-v2">
              <div class="badge-item">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="badge-text">Secure Payment</span>
              </div>
              <div class="badge-item">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="badge-text">Authenticity</span>
              </div>
              <div class="badge-item">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="3" width="15" height="13" rx="2" ry="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 8l4-4v11l-4-3V8z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="badge-text">Luxury Logistics</span>
              </div>
            </div>
            
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- AJAX Cart Logic -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('product-form-{{ section.id }}');
    if (!form) return;

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const btn = document.getElementById('main-atc-submit');
        if (!btn) return;

        btn.classList.add('loading');
        btn.innerText = 'ADDING TO COLLECTION...';

        let formData = new FormData(form);

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          body: formData,
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => {
          if (!response.ok) throw new Error('Cart addition failed');
          return response.json();
        })
        .then(item => {
          console.log('Product added successfully:', item);
          // Trigger the Cart Drawer
          document.dispatchEvent(new CustomEvent('cart:updated'));
          
          btn.innerText = 'ADDED SUCCESSFULLY';
          setTimeout(() => {
            btn.classList.remove('loading');
            btn.innerText = 'ADD TO CART';
          }, 2000);
        })
        .catch((error) => {
          console.error('Add to Cart Error:', error);
          btn.classList.remove('loading');
          btn.innerText = 'RETRY ADD';
          alert('Could not add to cart. Please check stock or try again.');
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Information",
  "blocks": [
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "variant_picker", "name": "Variant Picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy Buttons", "limit": 1 },
    { "type": "shipping_widget", "name": "Shipping Calculator", "limit": 1 },
    { "type": "description", "name": "Description", "limit": 1 }
  ]
}
{% endschema %}
