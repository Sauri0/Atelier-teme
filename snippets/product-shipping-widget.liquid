{% comment %}
  Product Shipping Widget - Dynamic Date Calculation without CLS
{% endcomment %}

<style>
  .shipping-widget {
    background-color: var(--color-surface);
    border-radius: var(--border-radius);
    padding: var(--spacing-md);
    margin-top: var(--spacing-md);
    min-height: 80px; /* Prevents CLS */
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .shipping-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-main);
  }

  .shipping-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    fill: var(--color-accent); /* Navy Green #1B263B */
  }

  .shipping-highlight {
    font-weight: 600;
    color: var(--color-primary); /* Aqua Green #20B2AA */
  }
</style>

{%- assign current_time = "now" | date: "%s" -%}
{%- assign seconds_in_day = 86400 -%}

{%- assign usa_start = 7 | times: seconds_in_day -%}
{%- assign usa_end = 10 | times: seconds_in_day -%}
{%- assign eur_start = 10 | times: seconds_in_day -%}
{%- assign eur_end = 15 | times: seconds_in_day -%}

{%- assign date_usa_start = current_time | plus: usa_start | date: "%b %d" -%}
{%- assign date_usa_end = current_time | plus: usa_end | date: "%b %d" -%}
{%- assign date_eur_start = current_time | plus: eur_start | date: "%b %d" -%}
{%- assign date_eur_end = current_time | plus: eur_end | date: "%b %d" -%}

<div class="shipping-widget">
  <div class="shipping-row">
    <!-- Truck Icon in Navy Green -->
    <svg class="shipping-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
    </svg>
    <span>
      <strong>USA Delivery:</strong> <span class="shipping-highlight">{{ date_usa_start }} - {{ date_usa_end }}</span>
    </span>
  </div>
  <div class="shipping-row">
    <!-- Globe Icon in Navy Green -->
    <svg class="shipping-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
    </svg>
    <span>
      <strong>Europe Delivery:</strong> <span class="shipping-highlight">{{ date_eur_start }} - {{ date_eur_end }}</span>
    </span>
  </div>
</div>
